# Server Configuration
PORT=3000
HOST=localhost

# CORS - comma-separated list of allowed origins (use * for all)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cache TTL in seconds (default: 5 minutes)
CACHE_TTL=300

# iTunes/Apple Music Search API base URL (free, no key required)
ITUNES_API_BASE=https://itunes.apple.com

# Optional: last.fm API key for extended metadata / recommendations
# LASTFM_API_KEY=your_lastfm_api_key_here
# LASTFM_API_BASE=https://ws.audioscrobbler.com/2.0
